---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Book a Call — Evergreen Events">
  <!-- Hero -->
  <section class="pt-36 pb-20 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-5 lg:col-start-2">
          <p class="section-label mb-4">Schedule</p>
          <h1 class="font-heading text-5xl md:text-6xl mb-6">Book a Call</h1>
        </div>
        <div class="lg:col-span-4 lg:col-start-8 flex items-end pb-2">
          <p class="text-[var(--color-text-secondary)] leading-relaxed">Pick a time for a free 30-minute discovery call. We'll discuss your event vision, budget, and next steps.</p>
        </div>
      </div>
      <div class="mt-10 flex items-center gap-4">
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
        <div class="w-1.5 h-1.5 border border-[var(--color-sage)] rotate-45"></div>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      </div>
    </div>
  </section>

  <!-- CAL.COM BOOKING -->
  <section class="pb-28 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <!-- Cal embed -->
        <div class="lg:col-span-7 lg:col-start-2 reveal">
          <div id="cal-embed" style="width:100%; min-height:550px; overflow:auto; border: 1px solid var(--color-border); background: white;"></div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-3 lg:col-start-10 reveal">
          <!-- What to expect -->
          <div class="border border-[var(--color-border)] bg-[var(--color-cream)] p-8 mb-10">
            <h3 class="font-heading text-xl mb-5">What to Expect</h3>
            <ul class="space-y-4 text-sm text-[var(--color-text-secondary)]">
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 mt-0.5 flex-shrink-0 flex items-center justify-center border border-[var(--color-sage)] rounded-full">
                  <div class="w-1.5 h-1.5 bg-[var(--color-gold)] rounded-full"></div>
                </div>
                <span>Share your event vision and priorities</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 mt-0.5 flex-shrink-0 flex items-center justify-center border border-[var(--color-sage)] rounded-full">
                  <div class="w-1.5 h-1.5 bg-[var(--color-gold)] rounded-full"></div>
                </div>
                <span>Discuss your budget and timeline</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 mt-0.5 flex-shrink-0 flex items-center justify-center border border-[var(--color-sage)] rounded-full">
                  <div class="w-1.5 h-1.5 bg-[var(--color-gold)] rounded-full"></div>
                </div>
                <span>Explore the right package for you</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 mt-0.5 flex-shrink-0 flex items-center justify-center border border-[var(--color-sage)] rounded-full">
                  <div class="w-1.5 h-1.5 bg-[var(--color-gold)] rounded-full"></div>
                </div>
                <span>Get a clear outline of next steps</span>
              </li>
            </ul>
          </div>

          <!-- Mini testimonial -->
          <div class="border border-[var(--color-border)] bg-[var(--color-cream)] p-8 mb-10">
            <svg class="mb-4 text-[var(--color-sage-muted)]" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.68 11 13.173 11 15c0 1.933-1.567 3.5-3.5 3.5-1.312 0-2.508-.629-2.917-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C19.591 11.68 21 13.173 21 15c0 1.933-1.567 3.5-3.5 3.5-1.312 0-2.508-.629-2.917-1.179z"/></svg>
            <p class="font-heading-italic text-lg leading-relaxed mb-4">"From our very first call, we felt completely at ease. They just got it."</p>
            <div class="flex items-center gap-3">
              <div class="w-6 h-px bg-[var(--color-gold)]"></div>
              <p class="text-xs font-medium tracking-[2px] uppercase text-[var(--color-sage)]">Sarah &amp; James</p>
            </div>
          </div>

          <!-- Prefer to write? -->
          <div class="text-center">
            <p class="text-sm text-[var(--color-text-secondary)] mb-3">Prefer to write?</p>
            <a href="/enquiry" class="btn-outline-ev text-xs px-6 py-3">Send an Enquiry</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Cal.com namespace embed loader
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", { origin: "https://cal.com" });
    Cal("inline", {
      calLink: "alister-maddrell-rmtqo9/discovery",
      elementOrSelector: "#cal-embed",
      config: { theme: "light", styles: { branding: { brandColor: "#B8963E" } } }
    });
    Cal("ui", { hideEventTypeDetails: false });
  </script>
</Layout>
