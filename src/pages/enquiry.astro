---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Make an Enquiry — Evergreen Events">
  <section class="pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="section-label mb-3">Get in Touch</p>
        <h1 class="font-heading text-4xl md:text-5xl mb-4">Make an Enquiry</h1>
        <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto">Tell us about your event and we'll be in touch within 24 hours to arrange a complimentary consultation.</p>
      </div>

      <div id="enquiry-form" class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="form-label">Your Name *</label>
                <input type="text" id="name" name="name" required class="form-input" />
              </div>
              <div>
                <label for="email" class="form-label">Email *</label>
                <input type="email" id="email" name="email" required class="form-input" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="event-type" class="form-label">Event Type *</label>
                <select id="event-type" name="event_type" required class="form-select">
                  <option value="" disabled selected>Select event type</option>
                  <option value="wedding">Wedding</option>
                  <option value="corporate">Corporate Event</option>
                  <option value="private">Private Celebration</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="date" class="form-label">Preferred Date</label>
                <input type="date" id="date" name="event_date" class="form-input" />
              </div>
            </div>
            <div>
              <label for="vision" class="form-label">Tell Us About Your Vision</label>
              <textarea id="vision" name="vision" rows="5" class="form-input" placeholder="Describe your dream event — the mood, the style, any must-haves..."></textarea>
            </div>
            <button type="submit" class="btn-sage w-full sm:w-auto">Send Enquiry</button>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 reveal">
          <div class="aspect-[3/4] overflow-hidden mb-8">
            <img src="https://images.unsplash.com/photo-1521543832500-49e69fb2bea2?w=600&h=800&fit=crop&q=80" alt="Bride holding a lush floral bouquet of white and blush roses" class="w-full h-full object-cover" loading="lazy" />
          </div>

          <!-- Mini testimonial -->
          <div class="bg-[var(--color-cream)] p-6 mb-8">
            <svg class="mb-3 text-[var(--color-sage-light)]" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.68 11 13.173 11 15c0 1.933-1.567 3.5-3.5 3.5-1.312 0-2.508-.629-2.917-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C19.591 11.68 21 13.173 21 15c0 1.933-1.567 3.5-3.5 3.5-1.312 0-2.508-.629-2.917-1.179z"/></svg>
            <p class="font-heading-italic text-lg leading-relaxed mb-3">"The entire process was seamless. From our first call, we knew we were in the best hands."</p>
            <p class="text-xs font-semibold tracking-[2px] uppercase text-[var(--color-sage-light)]">Mia &amp; Lachlan</p>
          </div>

          <div class="space-y-5 text-sm">
            <div>
              <h3 class="font-semibold text-xs tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Studio</h3>
              <p>Studio 3, 22 Foveaux Street<br/>Surry Hills NSW 2010</p>
            </div>
            <div>
              <h3 class="font-semibold text-xs tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Phone</h3>
              <a href="tel:+61295558800" class="hover:text-[var(--color-sage)] transition-colors">02 9555 8800</a>
            </div>
            <div>
              <h3 class="font-semibold text-xs tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Email</h3>
              <a href="mailto:hello@evergreenevents.com.au" class="hover:text-[var(--color-sage)] transition-colors">hello@evergreenevents.com.au</a>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-center gap-4 my-16">
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
        <span class="text-xs font-semibold tracking-[2px] uppercase text-[var(--color-text-secondary)]">Or book a call directly</span>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      </div>

      <!-- CAL.COM BOOKING -->
      <div id="booking" class="max-w-2xl mx-auto reveal">
        <div class="text-center mb-10">
          <p class="section-label mb-3">Book a Call</p>
          <h2 class="font-heading text-3xl md:text-4xl mb-4">Schedule a Discovery Call</h2>
          <p class="text-[var(--color-text-secondary)] max-w-lg mx-auto text-sm leading-relaxed">Pick a time for a free 30-minute call to discuss your event vision, budget, and next steps.</p>
        </div>
        <div id="cal-embed" style="width:100%; min-height:450px; overflow:auto; border: 1px solid var(--color-border); background: white;"></div>
      </div>
    </div>
  </section>

  <script>
    // Cal.com namespace embed loader
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", { origin: "https://cal.com" });
    Cal("inline", {
      calLink: "alister-maddrell-rmtqo9/discovery",
      elementOrSelector: "#cal-embed",
      config: { theme: "light", styles: { branding: { brandColor: "#7D8B6A" } } }
    });
    Cal("ui", { hideEventTypeDetails: false });
  </script>
</Layout>
