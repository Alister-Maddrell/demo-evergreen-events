---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Make an Enquiry — Evergreen Events">
  <!-- Hero -->
  <section class="pt-36 pb-20 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-5 lg:col-start-2">
          <p class="section-label mb-4">Get in Touch</p>
          <h1 class="font-heading text-5xl md:text-6xl mb-6">Make an Enquiry</h1>
        </div>
        <div class="lg:col-span-4 lg:col-start-8 flex items-end pb-2">
          <p class="text-[var(--color-text-secondary)] leading-relaxed">Tell us about your event and we'll be in touch within 24 hours to arrange a complimentary consultation.</p>
        </div>
      </div>
      <div class="mt-10 flex items-center gap-4">
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
        <div class="w-1.5 h-1.5 border border-[var(--color-sage)] rotate-45"></div>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      </div>
    </div>
  </section>

  <section class="pb-28 px-6">
    <div class="max-w-7xl mx-auto">
      <div id="enquiry-form" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
        <!-- Form -->
        <div class="lg:col-span-6 lg:col-start-2 reveal">
          <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-7">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="form-label">Your Name *</label>
                <input type="text" id="name" name="name" required class="form-input" />
              </div>
              <div>
                <label for="email" class="form-label">Email *</label>
                <input type="email" id="email" name="email" required class="form-input" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="event-type" class="form-label">Event Type *</label>
                <select id="event-type" name="event_type" required class="form-select">
                  <option value="" disabled selected>Select event type</option>
                  <option value="wedding">Wedding</option>
                  <option value="corporate">Corporate Event</option>
                  <option value="private">Private Celebration</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="date" class="form-label">Preferred Date</label>
                <input type="date" id="date" name="event_date" class="form-input" />
              </div>
            </div>
            <div>
              <label for="vision" class="form-label">Tell Us About Your Vision</label>
              <textarea id="vision" name="vision" rows="6" class="form-input" placeholder="Describe your dream event — the mood, the style, any must-haves..."></textarea>
            </div>
            <button type="submit" class="btn-sage w-full sm:w-auto">Send Enquiry</button>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-3 lg:col-start-9 reveal">
          <div class="border border-[var(--color-border)] p-4 mb-10">
            <div class="aspect-[3/4] overflow-hidden">
              <img src="https://images.unsplash.com/photo-1521543832500-49e69fb2bea2?w=600&h=800&fit=crop&q=80" alt="Bride holding a lush floral bouquet of white and blush roses" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>

          <!-- Mini testimonial -->
          <div class="border border-[var(--color-border)] bg-[var(--color-cream)] p-8 mb-10">
            <svg class="mb-4 text-[var(--color-sage-muted)]" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.68 11 13.173 11 15c0 1.933-1.567 3.5-3.5 3.5-1.312 0-2.508-.629-2.917-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C19.591 11.68 21 13.173 21 15c0 1.933-1.567 3.5-3.5 3.5-1.312 0-2.508-.629-2.917-1.179z"/></svg>
            <p class="font-heading-italic text-lg leading-relaxed mb-4">"The entire process was seamless. From our first call, we knew we were in the best hands."</p>
            <div class="flex items-center gap-3">
              <div class="w-6 h-px bg-[var(--color-gold)]"></div>
              <p class="text-xs font-medium tracking-[2px] uppercase text-[var(--color-sage)]">Mia &amp; Lachlan</p>
            </div>
          </div>

          <div class="space-y-6 text-sm">
            <div>
              <h3 class="font-medium text-[0.6875rem] tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Studio</h3>
              <p>Studio 3, 22 Foveaux Street<br/>Surry Hills NSW 2010</p>
            </div>
            <div>
              <h3 class="font-medium text-[0.6875rem] tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Phone</h3>
              <a href="tel:+61295558800" class="hover:text-[var(--color-gold)] transition-colors">02 9555 8800</a>
            </div>
            <div>
              <h3 class="font-medium text-[0.6875rem] tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Email</h3>
              <a href="mailto:hello@evergreenevents.com.au" class="hover:text-[var(--color-gold)] transition-colors">hello@evergreenevents.com.au</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Prefer to book a call -->
      <div class="max-w-xl mx-auto text-center mt-16 reveal">
        <div class="border border-[var(--color-border)] bg-[var(--color-cream)] p-10">
          <p class="section-label mb-3">Prefer to Chat?</p>
          <h3 class="font-heading text-2xl mb-4">Book a Discovery Call</h3>
          <p class="text-sm text-[var(--color-text-secondary)] mb-6 leading-relaxed">Schedule a free 30-minute call to discuss your vision in person.</p>
          <a href="/booking" class="btn-sage">Book a Call</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
