---
import '../styles/global.css';
interface Props { title: string; description?: string; }
const { title, description = "Evergreen Events — Sydney's award-winning wedding & event design studio. Your day, designed." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://images.unsplash.com/photo-1519741497674-611481863552?w=1200&h=630&fit=crop&q=80" />
  <meta name="twitter:card" content="summary_large_image" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "EventPlanner",
    "name": "Evergreen Events", "url": "https://evergreenevents.com.au",
    "telephone": "+61295558800", "email": "hello@evergreenevents.com.au",
    "address": { "@type": "PostalAddress", "streetAddress": "Studio 3, 22 Foveaux Street",
      "addressLocality": "Surry Hills", "addressRegion": "NSW", "postalCode": "2010", "addressCountry": "AU" }
  })} />
</head>
<body class="antialiased">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-sage focus:text-white focus:px-4 focus:py-2">Skip to content</a>
  <!-- Nav -->
  <nav class="nav-ev" id="main-nav">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="flex items-center justify-between h-[72px]">
        <a href="/" class="font-heading-italic text-2xl">Evergreen</a>
        <div class="hidden md:flex items-center gap-8">
          <a href="/portfolio" class="nav-link-ev">Portfolio</a>
          <a href="/services" class="nav-link-ev">Services</a>
          <a href="/enquiry" class="nav-link-ev">Enquiry</a>
        </div>
        <button class="md:hidden p-2" id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
      <div class="mobile-menu-ev md:hidden" id="mobile-menu">
        <div class="pb-4 flex flex-col gap-3">
          <a href="/portfolio" class="nav-link-ev py-2">Portfolio</a>
          <a href="/services" class="nav-link-ev py-2">Services</a>
          <a href="/enquiry" class="nav-link-ev py-2">Enquiry</a>
        </div>
      </div>
    </div>
  </nav>
  <main id="main-content"><slot /></main>
  <!-- Footer -->
  <footer class="footer-ev">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <a href="/" class="font-heading-italic text-2xl text-white">Evergreen</a>
          <p class="mt-4 text-sm">Your Day, Designed.<br/>Sydney's award-winning event design studio.</p>
        </div>
        <div>
          <h4 class="text-xs font-semibold tracking-widest uppercase text-white/80 mb-4">Quick Links</h4>
          <ul class="space-y-2 text-sm"><li><a href="/portfolio">Portfolio</a></li><li><a href="/services">Services & Packages</a></li><li><a href="/enquiry">Make an Enquiry</a></li></ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold tracking-widest uppercase text-white/80 mb-4">Contact</h4>
          <ul class="space-y-2 text-sm">
            <li>Studio 3, 22 Foveaux St, Surry Hills 2010</li>
            <li><a href="tel:+61295558800">02 9555 8800</a></li>
            <li><a href="mailto:hello@evergreenevents.com.au">hello@evergreenevents.com.au</a></li>
            <li><a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer">@evergreenevents_</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-12 pt-8 border-t border-white/10 text-xs text-white/30 text-center">
        &copy; {new Date().getFullYear()} Evergreen Events. ABN 33 456 789 012. All rights reserved.
      </div>
    </div>
  </footer>
  <script>
    const nav = document.getElementById('main-nav');
    if (nav) window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 20), { passive: true });
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) menuBtn.addEventListener('click', () => {
      const open = mobileMenu.classList.toggle('open');
      menuBtn.setAttribute('aria-expanded', String(open));
    });
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
  <script>
    if (new URLSearchParams(window.location.search).has('preview')) {
      document.documentElement.style.scrollBehavior = 'auto';
      document.querySelectorAll('img[loading="lazy"]').forEach(img => (img as HTMLImageElement).loading = 'eager');
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
      let scrolling = false, pos = 0, dir = 1, last = 0, rafId = 0;
      const pxPerSec = 150;
      function autoScroll(ts: number) { if (!scrolling) return; if (!last) last = ts;
        const dt = ts - last; last = ts;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        pos += dir * pxPerSec * (dt / 1000);
        if (pos >= max) { dir = -1; pos = max; } if (pos <= 0) { dir = 1; pos = 0; }
        window.scrollTo(0, pos); rafId = requestAnimationFrame(autoScroll); }
      window.addEventListener('message', e => {
        if (e.data === 'start-scroll') { if (!scrolling) { scrolling = true; last = 0; rafId = requestAnimationFrame(autoScroll); } }
        else if (e.data === 'stop-scroll') { scrolling = false; cancelAnimationFrame(rafId); pos = 0; dir = 1; window.scrollTo(0, 0); }
      });
    }
  </script>
</body>
</html>
