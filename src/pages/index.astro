---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Evergreen Events — Your Day, Designed">
  <!-- Hero -->
  <section class="hero-section relative min-h-dvh flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1519741497674-611481863552?w=1920&h=1080&fit=crop&q=80" alt="Elegant reception venue with warm string lights at dusk" class="w-full h-full object-cover hero-img" />
    </div>
    <div class="absolute inset-0 hero-overlay"></div>

    <!-- Decorative vertical line -->
    <div class="hero-vert-line hidden lg:block"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center min-h-dvh py-32">
        <!-- Left text panel -->
        <div class="lg:col-span-6 lg:col-start-1">
          <div class="hero-content">
            <div class="hero-overline mb-8">
              <span class="hero-overline-line"></span>
              <p class="section-label !text-white/50">Sydney's Award-Winning Event Studio</p>
            </div>
            <h1 class="font-heading-italic text-6xl sm:text-7xl md:text-8xl lg:text-[8.5rem] leading-[0.88] mb-10 hero-title">
              <span class="hero-title-line" style="--delay: 0">Your</span><br/>
              <span class="hero-title-line" style="--delay: 1">Day,</span><br/>
              <span class="hero-title-line hero-title-accent" style="--delay: 2">Designed</span>
            </h1>
            <p class="text-lg sm:text-xl font-light leading-relaxed mb-12 max-w-lg text-white/80 hero-fade-up" style="--delay: 3">We craft unforgettable weddings, corporate events, and private celebrations — with meticulous detail and genuine heart.</p>
            <div class="flex flex-wrap gap-5 hero-fade-up" style="--delay: 4">
              <a href="/enquiry" class="btn-sage">Start Planning</a>
              <a href="/portfolio" class="btn-outline-ev !border-white/30 !text-white hover:!bg-white/10">View Portfolio</a>
            </div>
          </div>
        </div>

        <!-- Right decorative image -->
        <div class="hidden lg:block lg:col-span-5 lg:col-start-8">
          <div class="hero-image-stack">
            <div class="hero-image-main">
              <div class="hero-image-frame-inner">
                <img src="https://images.unsplash.com/photo-1529635859953-7f7b2f931435?w=600&h=800&fit=crop&q=80" alt="Bridal bouquet detail" class="w-full h-full object-cover" />
              </div>
            </div>
            <div class="hero-image-secondary">
              <img src="https://images.unsplash.com/photo-1525441273400-056e9c7517b3?w=300&h=400&fit=crop&q=80" alt="Table styling detail" class="w-full h-full object-cover" />
            </div>
            <div class="hero-image-badge">
              <span class="font-heading-italic text-2xl text-white">Est.</span>
              <span class="font-heading text-4xl text-[var(--color-gold)]">2016</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hero-scroll-indicator z-10">
      <div class="flex flex-col items-center gap-3">
        <span class="text-[0.6rem] font-medium tracking-[4px] uppercase text-white/30">Scroll</span>
        <div class="w-px h-10 bg-gradient-to-b from-white/30 to-transparent hero-scroll-line"></div>
      </div>
    </div>
  </section>

  <!-- As Featured In -->
  <section class="py-16 border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-center text-[0.6875rem] font-medium tracking-[3px] uppercase text-[var(--color-text-secondary)] mb-10">As Featured In</p>
      <div class="flex flex-wrap items-center justify-center gap-5">
        <span class="featured-logo font-heading-italic text-3xl text-[var(--color-text-secondary)]/70">Vogue Bride</span>
        <span class="featured-logo font-heading text-xl tracking-[4px] uppercase text-[var(--color-text-secondary)]/70">Hello May</span>
        <span class="featured-logo font-heading-italic text-2xl text-[var(--color-text-secondary)]/70">Nouba</span>
        <span class="featured-logo font-heading text-lg tracking-[6px] uppercase font-semibold text-[var(--color-text-secondary)]/70">The Lane</span>
      </div>
    </div>
  </section>

  <!-- Services Overview — Editorial Asymmetric Layout -->
  <section class="py-36 md:py-40 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-20">
        <div class="lg:col-span-4 lg:col-start-2 reveal">
          <p class="section-label mb-4">What We Do</p>
          <h2 class="font-heading text-4xl md:text-5xl lg:text-[3.5rem] leading-[1.05]">Events Worth Remembering</h2>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <a href="/services" class="group reveal stagger-1 service-card">
          <div class="aspect-[3/4] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1529635859953-7f7b2f931435?w=600&h=800&fit=crop&q=80" alt="Bride holding a white bouquet at an outdoor ceremony" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="service-card-inner">
            <h3 class="font-heading text-2xl mb-3">Weddings</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">From intimate garden ceremonies to grand harbour-side receptions — we bring your love story to life with beauty and precision.</p>
          </div>
        </a>
        <a href="/services" class="group reveal stagger-2 service-card md:mt-12">
          <div class="aspect-[3/4] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1766164416026-1a823688d106?w=600&h=800&fit=crop&q=80" alt="Elegant corporate dining setup with candles and place settings" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="service-card-inner">
            <h3 class="font-heading text-2xl mb-3">Corporate Events</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Launches, galas, and brand activations designed to impress — polished production with personality.</p>
          </div>
        </a>
        <a href="/services" class="group reveal stagger-3 service-card md:mt-24">
          <div class="aspect-[3/4] overflow-hidden">
            <img src="https://images.unsplash.com/photo-1525441273400-056e9c7517b3?w=600&h=800&fit=crop&q=80" alt="Beautifully styled private dinner table with floral centrepieces" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="service-card-inner">
            <h3 class="font-heading text-2xl mb-3">Private Celebrations</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Milestone birthdays, engagement parties, and intimate gatherings — moments that deserve the extra touch.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Wedding — Editorial Split -->
  <section class="py-36 md:py-40 bg-[var(--color-cream)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-6 items-center">
        <div class="lg:col-span-6 reveal">
          <div class="featured-image-frame">
            <div class="aspect-[4/5] overflow-hidden">
              <img src="https://images.unsplash.com/photo-1595407753234-0882f1e77954?w=800&h=1000&fit=crop&q=80" alt="Sarah and James on their wedding day by Sydney Harbour" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 lg:col-start-8 reveal">
          <p class="section-label mb-5">Featured Wedding</p>
          <h2 class="font-heading-italic text-5xl md:text-6xl mb-3">Sarah &amp; James</h2>
          <p class="text-xs font-medium tracking-[2.5px] uppercase text-[var(--color-mauve)] mb-8">A Harbour-Side Celebration</p>
          <div class="thin-divider mb-8"></div>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-5">What began as a vision for an intimate 80-guest celebration along Sydney Harbour became a breathtaking afternoon of coastal elegance — from the white orchid arch framing the Harbour Bridge to the candlelit reception at Sergeants' Mess.</p>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-10">Every detail was thoughtfully curated: hand-lettered calligraphy, a bespoke floral palette of ivory roses and silver-dollar eucalyptus, and a three-course menu by Matt Moran's team. The result? An effortless, magazine-worthy day that felt unmistakably <em>them</em>.</p>
          <div class="flex flex-wrap gap-4">
            <a href="/portfolio" class="btn-outline-ev">View Full Gallery</a>
            <a href="/booking" class="btn-sage">Book a Discovery Call</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial — Pull Quote Style -->
  <section class="py-36 md:py-40 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="testimonial-card-ev text-center reveal">
        <svg class="mx-auto mb-10 text-[var(--color-sage-muted)]" width="44" height="44" viewBox="0 0 24 24" fill="currentColor"><path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.68 11 13.173 11 15c0 1.933-1.567 3.5-3.5 3.5-1.312 0-2.508-.629-2.917-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C19.591 11.68 21 13.173 21 15c0 1.933-1.567 3.5-3.5 3.5-1.312 0-2.508-.629-2.917-1.179z"/></svg>
        <blockquote class="font-heading-italic text-2xl md:text-[2rem] leading-relaxed mb-10 max-w-2xl mx-auto">"From the first meeting to the last dance, the Evergreen team made everything feel effortless. Our wedding was beyond anything we imagined — elegant, personal, and absolutely magical."</blockquote>
        <div class="flex items-center justify-center gap-4 mb-1">
          <div class="w-8 h-px bg-[var(--color-gold)]"></div>
          <p class="text-xs font-medium tracking-[2.5px] uppercase text-[var(--color-sage)]">Sarah &amp; James Whitfield</p>
          <div class="w-8 h-px bg-[var(--color-gold)]"></div>
        </div>
        <p class="text-xs text-[var(--color-text-secondary)] mt-2">Sergeants' Mess, Mosman — March 2025</p>
      </div>
    </div>
  </section>

  <!-- Instagram Feed -->
  <section class="py-36 md:py-40 px-6 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 reveal">
        <p class="section-label mb-4">Instagram</p>
        <h2 class="font-heading-italic text-3xl md:text-4xl">Follow Along <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-gold)] transition-colors">@evergreenevents_</a></h2>
      </div>
      <div class="insta-grid-frame reveal">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
          <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer" class="aspect-square overflow-hidden group">
            <img src="https://images.unsplash.com/photo-1519741497674-611481863552?w=400&h=400&fit=crop&q=80" alt="Instagram post — wedding couple" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          </a>
          <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer" class="aspect-square overflow-hidden group">
            <img src="https://images.unsplash.com/photo-1529635859953-7f7b2f931435?w=400&h=400&fit=crop&q=80" alt="Instagram post — bridal bouquet" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          </a>
          <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer" class="aspect-square overflow-hidden group">
            <img src="https://images.unsplash.com/photo-1595407753234-0882f1e77954?w=400&h=400&fit=crop&q=80" alt="Instagram post — reception setup" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          </a>
          <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer" class="aspect-square overflow-hidden group">
            <img src="https://images.unsplash.com/photo-1525441273400-056e9c7517b3?w=400&h=400&fit=crop&q=80" alt="Instagram post — table styling" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          </a>
          <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer" class="aspect-square overflow-hidden group">
            <img src="https://images.unsplash.com/photo-1766164416026-1a823688d106?w=400&h=400&fit=crop&q=80" alt="Instagram post — corporate event" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          </a>
          <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer" class="aspect-square overflow-hidden group">
            <img src="https://images.unsplash.com/photo-1521543832500-49e69fb2bea2?w=400&h=400&fit=crop&q=80" alt="Instagram post — floral arrangement" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
