---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Make an Enquiry — Evergreen Events">
  <section class="pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="section-label mb-3">Get in Touch</p>
        <h1 class="font-heading text-4xl md:text-5xl mb-4">Make an Enquiry</h1>
        <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto">Tell us about your event and we'll be in touch within 24 hours to arrange a complimentary consultation.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="form-label">Your Name *</label>
                <input type="text" id="name" name="name" required class="form-input" />
              </div>
              <div>
                <label for="partner" class="form-label">Partner's Name</label>
                <input type="text" id="partner" name="partner" class="form-input" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="form-label">Email *</label>
                <input type="email" id="email" name="email" required class="form-input" />
              </div>
              <div>
                <label for="phone" class="form-label">Phone</label>
                <input type="tel" id="phone" name="phone" class="form-input" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="event-type" class="form-label">Event Type *</label>
                <select id="event-type" name="event_type" required class="form-select">
                  <option value="" disabled selected>Select event type</option>
                  <option value="wedding">Wedding</option>
                  <option value="corporate">Corporate Event</option>
                  <option value="private">Private Celebration</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="guests" class="form-label">Estimated Guest Count</label>
                <select id="guests" name="guest_count" class="form-select">
                  <option value="" disabled selected>Select range</option>
                  <option value="under-50">Under 50</option>
                  <option value="50-100">50 – 100</option>
                  <option value="100-150">100 – 150</option>
                  <option value="150-200">150 – 200</option>
                  <option value="200+">200+</option>
                </select>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="date" class="form-label">Preferred Date</label>
                <input type="date" id="date" name="event_date" class="form-input" />
              </div>
              <div>
                <label for="venue" class="form-label">Venue (if confirmed)</label>
                <input type="text" id="venue" name="venue" class="form-input" placeholder="e.g. Sergeants' Mess" />
              </div>
            </div>
            <div>
              <label for="budget" class="form-label">Budget Range</label>
              <select id="budget" name="budget" class="form-select">
                <option value="" disabled selected>Select range</option>
                <option value="under-10k">Under $10,000</option>
                <option value="10k-25k">$10,000 – $25,000</option>
                <option value="25k-50k">$25,000 – $50,000</option>
                <option value="50k-100k">$50,000 – $100,000</option>
                <option value="100k+">$100,000+</option>
              </select>
            </div>
            <div>
              <label for="vision" class="form-label">Tell Us About Your Vision</label>
              <textarea id="vision" name="vision" rows="5" class="form-input" placeholder="Describe your dream event — the mood, the style, any must-haves..."></textarea>
            </div>
            <div>
              <label for="referral" class="form-label">How Did You Hear About Us?</label>
              <select id="referral" name="referral" class="form-select">
                <option value="" disabled selected>Select one</option>
                <option value="instagram">Instagram</option>
                <option value="google">Google Search</option>
                <option value="referral">Friend / Family Referral</option>
                <option value="venue">Venue Recommendation</option>
                <option value="publication">Magazine / Blog</option>
                <option value="other">Other</option>
              </select>
            </div>
            <button type="submit" class="btn-sage w-full sm:w-auto">Send Enquiry</button>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 reveal">
          <div class="aspect-[3/4] overflow-hidden mb-8">
            <img src="https://images.unsplash.com/photo-1521543832500-49e69fb2bea2?w=600&h=800&fit=crop&q=80" alt="Bride holding a lush floral bouquet of white and blush roses" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="space-y-5 text-sm">
            <div>
              <h3 class="font-semibold text-xs tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Studio</h3>
              <p>Studio 3, 22 Foveaux Street<br/>Surry Hills NSW 2010</p>
            </div>
            <div>
              <h3 class="font-semibold text-xs tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Phone</h3>
              <a href="tel:+61295558800" class="hover:text-[var(--color-sage)] transition-colors">02 9555 8800</a>
            </div>
            <div>
              <h3 class="font-semibold text-xs tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Email</h3>
              <a href="mailto:hello@evergreenevents.com.au" class="hover:text-[var(--color-sage)] transition-colors">hello@evergreenevents.com.au</a>
            </div>
            <div>
              <h3 class="font-semibold text-xs tracking-[2px] uppercase text-[var(--color-text-secondary)] mb-2">Instagram</h3>
              <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-sage)] transition-colors">@evergreenevents_</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
