---
import '../styles/global.css';
interface Props { title: string; description?: string; }
const { title, description = "Evergreen Events — Sydney's award-winning wedding & event design studio. Your day, designed." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://images.unsplash.com/photo-1519741497674-611481863552?w=1200&h=630&fit=crop&q=80" />
  <meta name="twitter:card" content="summary_large_image" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400;1,9..144,500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "EventPlanner",
    "name": "Evergreen Events", "url": "https://evergreenevents.com.au",
    "telephone": "+61295558800", "email": "hello@evergreenevents.com.au",
    "address": { "@type": "PostalAddress", "streetAddress": "Studio 3, 22 Foveaux Street",
      "addressLocality": "Surry Hills", "addressRegion": "NSW", "postalCode": "2010", "addressCountry": "AU" }
  })} />
</head>
<body class="antialiased">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-[var(--color-gold)] focus:text-white focus:px-4 focus:py-2">Skip to content</a>

  <!-- Nav -->
  <nav class="nav-ev" id="main-nav">
    <div class="nav-accent-line"></div>
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="flex items-center justify-between h-[100px]">
        <div class="hidden md:flex items-center gap-10 flex-1">
          <a href="/portfolio" class="nav-link-ev">Portfolio</a>
          <a href="/services" class="nav-link-ev">Services</a>
        </div>
        <a href="/" class="nav-logo font-heading-italic text-3xl tracking-wide relative">
          Evergreen
          <span class="nav-logo-accent"></span>
        </a>
        <div class="hidden md:flex items-center gap-10 flex-1 justify-end">
          <a href="/enquiry" class="nav-link-ev">Enquiry</a>
          <a href="/booking" class="nav-cta-btn">Book Now</a>
        </div>
        <button class="md:hidden p-2 hamburger flex flex-col gap-[6px]" id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
      <div class="mobile-menu-ev md:hidden" id="mobile-menu">
        <div class="pb-6 flex flex-col gap-4">
          <a href="/portfolio" class="nav-link-ev py-2">Portfolio</a>
          <a href="/services" class="nav-link-ev py-2">Services</a>
          <a href="/enquiry" class="nav-link-ev py-2">Enquiry</a>
        </div>
      </div>
    </div>
  </nav>

  <main id="main-content"><slot /></main>

  <!-- Botanical divider above footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="flex items-center gap-4">
      <div class="flex-1 h-px bg-[var(--color-sage-muted)]"></div>
      <div class="w-2 h-2 border border-[var(--color-sage)] rotate-45"></div>
      <div class="flex-1 h-px bg-[var(--color-sage-muted)]"></div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer-ev">
    <div class="max-w-5xl mx-auto px-6 lg:px-12 py-24">
      <div class="text-center">
        <a href="/" class="font-heading-italic text-3xl text-white">Evergreen</a>
        <p class="mt-3 text-sm text-white/40 font-heading-italic tracking-wide">Your Day, Designed.</p>
      </div>

      <!-- Newsletter -->
      <div class="mt-14 max-w-md mx-auto">
        <p class="text-center text-[0.6875rem] font-medium tracking-[3px] uppercase text-white/35 mb-5">Stay Inspired</p>
        <form class="flex flex-col sm:flex-row gap-3" action="https://formspree.io/f/placeholder" method="POST">
          <input type="email" name="email" required placeholder="your@email.com" class="flex-1 px-5 py-3.5 bg-white/8 border border-white/12 text-white placeholder:text-white/30 text-sm focus:outline-none focus:border-[var(--color-gold)]" />
          <button type="submit" class="px-7 py-3.5 bg-[var(--color-gold)] text-white text-xs font-medium tracking-[2px] uppercase font-heading hover:bg-[var(--color-gold-dark)] transition-colors">Subscribe</button>
        </form>
      </div>

      <!-- Contact row -->
      <div class="mt-14 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-white/45">
        <span>Studio 3, 22 Foveaux St, Surry Hills 2010</span>
        <span class="hidden sm:inline text-white/15">&#183;</span>
        <a href="tel:+61295558800">02 9555 8800</a>
        <span class="hidden sm:inline text-white/15">&#183;</span>
        <a href="mailto:hello@evergreenevents.com.au">hello@evergreenevents.com.au</a>
        <span class="hidden sm:inline text-white/15">&#183;</span>
        <a href="https://www.instagram.com/evergreenevents_" target="_blank" rel="noopener noreferrer">@evergreenevents_</a>
      </div>

      <div class="mt-14 pt-8 border-t border-white/8 text-xs text-white/25 text-center">
        &copy; {new Date().getFullYear()} Evergreen Events. ABN 33 456 789 012. All rights reserved.
      </div>
    </div>
  </footer>

  <!-- Floating Booking Button -->
  <div class="floating-book-btn" id="floating-book">
    <a href="/booking" class="floating-book-link" aria-label="Book a discovery call">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      <span class="floating-book-label">Book a Call</span>
    </a>
  </div>

  <script>
    const nav = document.getElementById('main-nav');
    if (nav) window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 20), { passive: true });
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) menuBtn.addEventListener('click', () => {
      const open = mobileMenu.classList.toggle('open');
      menuBtn.classList.toggle('open', open);
      menuBtn.setAttribute('aria-expanded', String(open));
    });
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Floating booking button — show after scroll, hide on /booking page
    const floatingBtn = document.getElementById('floating-book');
    if (floatingBtn) {
      const isBookingPage = window.location.pathname.startsWith('/booking');
      if (isBookingPage) {
        floatingBtn.remove();
      } else {
        window.addEventListener('scroll', () => {
          floatingBtn.classList.toggle('visible', window.scrollY > 300);
        }, { passive: true });
      }
    }
  </script>
  <script>
    if (new URLSearchParams(window.location.search).has('preview')) {
      document.documentElement.style.scrollBehavior = 'auto';
      document.querySelectorAll('img[loading="lazy"]').forEach(img => (img as HTMLImageElement).loading = 'eager');
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
      // Disable hero animations during scroll preview
      const heroImg = document.querySelector('.hero-img') as HTMLElement;
      if (heroImg) heroImg.style.animation = 'none';
      const heroContent = document.querySelector('.hero-content') as HTMLElement;
      if (heroContent) heroContent.style.animation = 'none';
      let scrolling = false, pos = 0, dir = 1, last = 0, rafId = 0;
      const pxPerSec = 150;
      function autoScroll(ts: number) { if (!scrolling) return; if (!last) last = ts;
        const dt = ts - last; last = ts;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        pos += dir * pxPerSec * (dt / 1000);
        if (pos >= max) { dir = -1; pos = max; } if (pos <= 0) { dir = 1; pos = 0; }
        window.scrollTo(0, pos); rafId = requestAnimationFrame(autoScroll); }
      window.addEventListener('message', e => {
        if (e.data === 'start-scroll') { if (!scrolling) { scrolling = true; last = 0; rafId = requestAnimationFrame(autoScroll); } }
        else if (e.data === 'stop-scroll') { scrolling = false; cancelAnimationFrame(rafId); pos = 0; dir = 1; window.scrollTo(0, 0); }
      });
    }
  </script>
</body>
</html>
